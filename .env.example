HOST=0.0.0.0
PORT=3000

# HTTPS enabled by default (set false to use plain HTTP).
HTTPS=true
SSL_KEY_PATH=.cert/localhost-key.pem
SSL_CERT_PATH=.cert/localhost-cert.pem

JWT_SECRET=change-this-secret
JWT_EXPIRES_IN=7d

# Optional: if empty, app uses in-memory MongoDB automatically.
MONGO_URI=
MONGO_DB_NAME=getex

# Allowed CORS origins. Use "*" for all, or comma-separated list.
APP_ORIGIN=*
